# ==================== FastAPI Server Configuration ====================
# Host and port for the API server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=False

# Enable/disable verbose logging
LOG_LEVEL=INFO


# ==================== Selenium Configuration ====================
# Headless mode (no browser window displayed)
SELENIUM_HEADLESS=True

# Wait timeout in seconds for page loads
SELENIUM_WAIT_TIMEOUT=10

# Implicit wait in seconds for element detection
SELENIUM_IMPLICIT_WAIT=5

# Take screenshot when error occurs
SCREENSHOT_ON_ERROR=True


# ==================== Image Preprocessing Configuration ====================
# Target image size for model input (pixels)
IMAGE_SIZE=224

# Center crop ratio (0.0 to 1.0)
# 0.6 means crop center 60% of image
CROP_RATIO=0.6

# HSV color space threshold for hue detection
HSV_HUE_THRESHOLD=15


# ==================== Model Configuration ====================
# Model architecture to use
MODEL_NAME=resnet18

# Number of output classes (color families)
NUM_CLASSES=10

# Path to trained model checkpoint
MODEL_CHECKPOINT=./models/resnet18_colors.pth

# Device for inference: 'cpu' or 'cuda'
# Use 'cuda' if GPU is available
DEVICE=cpu

# Confidence threshold for decision making (0.0 to 1.0)
# Results below this threshold are marked as UNCERTAIN
CONFIDENCE_THRESHOLD=0.70


# ==================== Database Configuration ====================
# Database type: 'supabase' or 'json'
DB_TYPE=json

# Supabase configuration (if using Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key
SUPABASE_TABLE=audit_results

# Local JSON database path (if using JSON storage)
JSON_DB_PATH=./data/database.json


# ==================== Logging Configuration ====================
# Log file location
LOG_FILE=./logs/neuralaudit.log

# Maximum log file size in bytes (10 MB default)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=5


# ==================== System Configuration ====================
# Maximum concurrent processing tasks
MAX_WORKERS=4

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Retry attempts for failed requests
RETRY_ATTEMPTS=3

# Retry delay in seconds
RETRY_DELAY=5
